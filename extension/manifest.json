{
    "manifest_version": 3,
    "name": "wLib",
    "version": "1.0.5",
    "description": "Send F95Zone games directly to your native wLib game manager.",
    "permissions": [],
    "host_permissions": [
        "http://localhost:8183/*"
    ],
    "background": {
        "service_worker": "background.js",
        "scripts": [
            "background.js"
        ],
        "type": "module"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "extension@wlib-app.com",
            "strict_min_version": "109.0"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://f95zone.to/threads/*",
                "*://f95zone.to/sam/latest_alpha*"
            ],
            "css": [
                "content.css"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icon.svg",
                "arrow-down-left.svg",
                "library-plus.svg",
                "external-link.svg"
            ],
            "matches": [
                "*://f95zone.to/*"
            ]
        }
    ],
    "icons": {
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "action": {
        "default_icon": "icon-48.png",
        "default_title": "wLib Integration"
    }
}
