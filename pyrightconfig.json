{
  "include": [
    "main.py",
    "core"
  ],
  "exclude": [
    "tests",
    "ui/node_modules",
    "ui/dist",
    "build",
    "dist",
    "node_modules",
    ".venv",
    "venv",
    ".ubuntuvenv",
    "test_venv"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "stubPath": "typings",
  "extraPaths": [
    "typings"
  ],
  "baselineFile": ".basedpyright/baseline.json",
  "pythonVersion": "3.12",
  "pythonPlatform": "Linux",
  "typeCheckingMode": "recommended",
  "strict": [
    "core/api.py",
    "core/database.py",
    "core/launcher.py",
    "core/scraper.py",
    "main.py"
  ],
  "reportMissingTypeStubs": false
}
